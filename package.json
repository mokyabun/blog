{
    "name": "blog",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@astrojs/mdx": "^5.0.3",
        "@astrojs/rss": "^4.0.18",
        "@astrojs/sitemap": "^3.7.2",
        "@tailwindcss/vite": "^4.2.2",
        "astro": "^6.1.1",
        "sharp": "^0.34.3",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2"
    },
    "devDependencies": {
        "prettier": "^3.8.1",
        "prettier-plugin-astro": "^0.14.1",
        "daisyui": "^5.5.19"
    },
    "prettier": {
        "plugins": [
            "prettier-plugin-astro"
        ],
        "overrides": [
            {
                "files": "*.astro",
                "options": {
                    "parser": "astro"
                }
            }
        ],
        "tabWidth": 4,
        "semi": false,
        "printWidth": 100
    }
}
