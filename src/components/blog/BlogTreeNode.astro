---
import BlogTreeNode from "./BlogTreeNode.astro"

export type FileNode = {
    type: "file"
    id: string
    title: string
}

export type FolderNode = {
    type: "folder"
    name: string
    children: Record<string, FileNode | FolderNode>
}

type Props = {
    name: string
    node: FileNode | FolderNode
    currentId: string
}

const { name, node, currentId } = Astro.props
const isActive =
    node.type === "file" &&
    node.id.replace(/\/index$/, "") === currentId.replace(/\/index$/, "")

const sortedChildren =
    node.type === "folder"
        ? Object.entries(node.children).sort(([, a], [, b]) => {
              if (a.type !== b.type) return a.type === "folder" ? -1 : 1
              return (a.type === "folder" ? a.name : a.title).localeCompare(
                  b.type === "folder" ? b.name : b.title,
              )
          })
        : []
---

{
    node.type === "file" ? (
        <li>
            <a href={`/blog/${node.id.replace(/\/index$/, "")}/`} class:list={[{ active: isActive }]} title={node.title}>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="shrink-0 opacity-60"
                >
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                </svg>
                <span class="truncate">{node.title}</span>
            </a>
        </li>
    ) : (
        <li>
            <details open>
                <summary>
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        class="shrink-0 opacity-60"
                    >
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                    </svg>
                    <span class="font-medium">{name}</span>
                </summary>
                <ul>
                    {sortedChildren.map(([childName, childNode]) => (
                        <BlogTreeNode name={childName} node={childNode} currentId={currentId} />
                    ))}
                </ul>
            </details>
        </li>
    )
}
