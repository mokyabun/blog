---
import Hero from "@/assets/hero.webp"
import BaseHead from "@/components/shared/BaseHead.astro"
import Footer from "@/components/shared/Footer.astro"
import Header from "@/components/shared/Header.astro"
import { SITE_DESCRIPTION, SITE_TITLE } from "@/consts"
import Title from "@/components/shared/Title.astro"
import BaseWebsite from "@/components/shared/BaseWebsite.astro"
---


<BaseWebsite>
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header transparentHeader={true} />
        <Title image={Hero} title={SITE_TITLE} description={SITE_DESCRIPTION} />
        <main class="lg:max-w-4xl lg:mx-auto px-4 py-8 bg-base-100">
            <div class="h-[1000vh] text-gray-600 mt-5 text-xs">아직 미완성 페이지입니다.</div>
        </main>
        <Footer />
    </body>
</BaseWebsite>

